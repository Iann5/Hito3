    {
      "parameters": {
        "jsCode": "const text = $json.text;\nconst words = text.split(/\\s+/);\nconst chunkSize = 500;\nconst overlap = 50;\nlet chunks = [];\n\n// Accedemos al nombre del archivo de forma más directa\nconst fileName = $('Webhook Ingesta').item.binary.file.fileName;\n\nfor (let i = 0; i < words.length; i += chunkSize - overlap) {\n    chunks.push({\n        chunk: words.slice(i, i + chunkSize).join(\" \"),\n        nombre_archivo: fileName,\n        total_chunks: Math.ceil(words.length / (chunkSize - overlap))\n    });\n}\n\nreturn chunks.map(c => ({ json: c }));"
      },
      "name": "Dividir en Chunks",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        0
      ],
      "id": "db5d02b8-cf47-4c78-b99e-b1cebfe2608f"
    },
